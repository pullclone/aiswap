# shellcheck shell=bash
#
# Compatibility loader for users who already source this file directly.

_aiswap_loader=${BASH_SOURCE[0]}
_aiswap_loader_dir=${_aiswap_loader%/*}
if [[ $_aiswap_loader_dir == "$_aiswap_loader" ]]; then
	_aiswap_loader_dir=.
fi

# shellcheck source=aiswap.sh
. "$_aiswap_loader_dir/aiswap.sh"

unset _aiswap_loader _aiswap_loader_dir
